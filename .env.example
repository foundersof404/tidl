# PrescribeRx Sandbox (token rotates every ~12h — see prescribe-rx-sandbox-tokens.md)
PRX_API_BASE_URL=https://demo.prescribe-rx.com/api/v1

# Single API token from PRX sandbox (format: {id}|{secret}) — server only, never in browser
PRX_API_TOKEN=

# Webhook signature verification (from PRX admin → Webhooks, when available)
PRX_WEBHOOK_SECRET=

# Optional: public base URL if a client-side helper needs the host (no secrets)
VITE_PRX_API_BASE_URL=https://demo.prescribe-rx.com/api/v1

# --- Optional: only if PRX issues separate production tokens later ---
# PRX_TOKEN_CLIENT=
# PRX_TOKEN_PATIENT=
# PRX_TOKEN_PROVIDER=
# PRX_TOKEN_SALES_ORG=
